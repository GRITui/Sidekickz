# Sidekick — LINE integration (api/line-webhook.js, api/booking-*.js)
# environment variables. Set the REAL values in the Vercel project's
# dashboard (Settings → Environment Variables), not in a local .env file
# that could get committed by accident. Never paste real values in chat, a
# commit message, or an issue/PR — rotate immediately if one ever leaks.

# LINE integration — pilot/single-tenant, one Channel.
# Get these from the LINE Developers Console → your Messaging API channel.
# LINE_CHANNEL_SECRET verifies incoming webhook signatures; it is NOT the
# same thing as a channel access token (that's fetched at runtime via
# client_credentials using the two values below, not stored separately).
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Optional: where the "book a slot" link in the auto-reply points. Defaults
# to the deployed app root if unset.
LINE_BOOKING_URL=

# The freelancer's own LINE user ID (not the OA's), so booking-request.js
# can push her an alert when a new request comes in. Get this from LINE's
# webhook event logs the first time she messages her own OA — there is no
# lookup-by-name API for this. Optional: without it, bookings still work,
# she just doesn't get pushed a notification for them.
LINE_FREELANCER_USER_ID=

# Neon Postgres — auto-provisioned by connecting the Neon integration in the
# Vercel dashboard (Storage → Marketplace). Do not set this by hand; if it's
# missing, the integration isn't connected yet. Shared by both sql/schema.sql
# (the single-tenant LINE booking pilot) and sql/schema-core.sql (the
# multi-tenant core-app tables from Phase 1 of the backend migration) — one
# Neon database, two independent schemas.
DATABASE_URL=

# LINE Login — "Continue with LINE" on app/login.html. This is a SEPARATE
# LINE channel from the Messaging API one above: create a channel of type
# "LINE Login" (not "Messaging API") in the LINE Developers Console, then
# get its own Channel ID/secret from that channel's "LINE Login" settings
# tab. Add exactly one callback URL there, matching LINE_LOGIN_CALLBACK_URL.
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# The deployed api/line-login-callback.js URL, e.g.
# https://sidekick.example.com/api/line-login-callback. Must match, exactly,
# a callback URL registered on the LINE Login channel above.
LINE_LOGIN_CALLBACK_URL=

# Any long random string (e.g. `openssl rand -base64 32`), used only to sign
# the OAuth `state` param so api/line-login-callback.js can verify it wasn't
# forged/replayed. Not a LINE credential — generate this yourself, unrelated
# to any LINE Developers Console value.
LINE_LOGIN_STATE_SECRET=

# Phase 1 of the local-first -> backend migration (api/auth-*.js,
# api/clients.js, api/migrate-upload.js, lib/auth.js). Any long random
# string (e.g. `openssl rand -base64 32`) — signs the bearer session token
# every authenticated request carries. Unrelated to LINE_LOGIN_STATE_SECRET
# (different purpose, different lifetime — a session lasts 30 days, an
# OAuth state token 10 minutes) — don't reuse one for the other.
SESSION_SECRET=
