# Sidekick — environment variables. Set the REAL values in the Vercel
# project's dashboard (Settings → Environment Variables), not in a local
# .env file that could get committed by accident. Never paste real values
# in chat, a commit message, or an issue/PR — rotate immediately if one
# ever leaks.

# 2026-07-14: LINE_CHANNEL_ID / LINE_CHANNEL_SECRET / LINE_BOOKING_URL /
# LINE_FREELANCER_USER_ID (a single hardcoded pilot Channel) are RETIRED —
# self-service booking is now generic/multi-tenant: every account connects
# its own LINE Official Account from Settings > LINE booking
# (api/line-channel-connect.js), and those credentials live per-account in
# the line_channels table (sql/schema-core.sql), never in env vars. Nothing
# to set here for LINE Messaging anymore. Optional overrides, sensible
# defaults if unset:
#   API_ORIGIN  — the deployed Vercel API origin (default:
#                 https://sidekickz.vercel.app), used to build the one
#                 shared webhook URL every connected account is shown.
#   APP_ORIGIN  — the deployed static-app origin (default:
#                 https://gritui.github.io/Sidekickz), used to build each
#                 account's own public booking-page URL (app/book.html),
#                 team invite links, AND (2026-07-16) the Stripe
#                 success/cancel/return redirect URLs — see lib/cors.js
#                 appUrl(): the app lives under a /Sidekickz project path
#                 on GitHub Pages, so a bare-origin redirect would 404.

# Neon Postgres — auto-provisioned by connecting the Neon integration in the
# Vercel dashboard (Storage → Marketplace). Do not set this by hand; if it's
# missing, the integration isn't connected yet.
DATABASE_URL=

# LINE Login — "Continue with LINE" on app/login.html. This is a SEPARATE
# LINE channel from the Messaging API one above: create a channel of type
# "LINE Login" (not "Messaging API") in the LINE Developers Console, then
# get its own Channel ID/secret from that channel's "LINE Login" settings
# tab. Add exactly one callback URL there, matching LINE_LOGIN_CALLBACK_URL.
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# The deployed api/line-login-callback.js URL, e.g.
# https://sidekick.example.com/api/line-login-callback. Must match, exactly,
# a callback URL registered on the LINE Login channel above.
LINE_LOGIN_CALLBACK_URL=

# Any long random string (e.g. `openssl rand -base64 32`), used only to sign
# the OAuth `state` param so api/line-login-callback.js can verify it wasn't
# forged/replayed. Not a LINE credential — generate this yourself, unrelated
# to any LINE Developers Console value.
LINE_LOGIN_STATE_SECRET=

# Phase 1 of the local-first -> backend migration (api/auth-*.js,
# api/clients.js, api/migrate-upload.js, lib/auth.js). Any long random
# string (e.g. `openssl rand -base64 32`) — signs the bearer session token
# every authenticated request carries. Unrelated to LINE_LOGIN_STATE_SECRET
# (different purpose, different lifetime — a session lasts 30 days, an
# OAuth state token 10 minutes) — don't reuse one for the other.
SESSION_SECRET=

# Subscription billing (Phase 0, api/billing-checkout.js/api/billing-portal.js
# /api/stripe-webhook.js/lib/stripe.js). From the Stripe Dashboard — use TEST
# mode keys (sk_test_.../whsec_test_...) until real billing is ready to go
# live, never paste real values in chat/commits.
STRIPE_SECRET_KEY=

# From Stripe Dashboard → Developers → Webhooks → add an endpoint pointing at
# the deployed api/stripe-webhook.js URL, subscribed to at minimum:
# customer.subscription.created, customer.subscription.updated,
# customer.subscription.deleted. Stripe shows this secret once, at endpoint
# creation (or "Reveal" on an existing one) — it is NOT the same as
# STRIPE_SECRET_KEY.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (price_...), NOT Product IDs — create a Product for each
# plan in the Stripe Dashboard (Products → Add product), then a recurring
# monthly THB Price under it, and paste that Price's id here. There is no
# API call anywhere in this codebase that creates these — same "set up by
# hand once" convention as running sql/schema-core.sql itself.
# STRIPE_PRICE_TEAM is a per-seat Price (Stripe Price "pricing model" ==
# "Standard pricing", quantity set by api/billing-checkout.js at Checkout
# time) — the same Price line-item quantity is what api/billing-portal.js's
# note below is describing when it says "customers can update quantities".
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# For Team-plan seat changes after the initial purchase: in the Stripe
# Dashboard, go to Settings → Billing → Customer portal, and under
# "Subscriptions" enable "Customers can update quantities" for the Team
# Price. Without this, an existing team can't add/remove seats from the
# Billing Portal (api/billing-portal.js) — api/stripe-webhook.js re-syncs
# users.team_seats automatically the moment that edit fires.

# One-shot schema-migration endpoint (api/admin-migrate.js) — kills the
# run-psql-against-the-wrong-Neon-database trap by applying
# sql/schema-core.sql through the SAME DATABASE_URL the deployed app uses.
# Any long random string (e.g. `openssl rand -base64 32`). While unset, the
# endpoint answers 404 (disabled). Setup flow:
#   1. set SETUP_TOKEN in Vercel, redeploy
#   2. status: curl https://<api>/api/admin-migrate -H "x-setup-token: $T"
#   3. apply : curl -X POST (same URL and header)
#   4. REMOVE SETUP_TOKEN from Vercel (re-disables the endpoint)
# Safe to re-run any time — the schema is idempotent, additive-only DDL.
SETUP_TOKEN=

# T-24h LINE booking reminders (api/cron-reminders.js), invoked hourly by
# the Vercel Cron entry in vercel.json ("0 * * * *"). Any long random string
# (e.g. `openssl rand -base64 32`). Once this env var exists on the Vercel
# project, Vercel automatically sends it back as `Authorization: Bearer
# <value>` on every cron-triggered request — nothing to configure on the
# cron side itself. While unset, the endpoint answers 404 (same disabled
# posture as SETUP_TOKEN above) and the hourly cron hit is a harmless
# no-op, so reminders stay OFF until this is set. Unlike SETUP_TOKEN,
# leave this one set permanently — it isn't a one-shot setup secret, it
# gates a recurring feature.
CRON_SECRET=
