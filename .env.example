# Freelanz — M-AI (Vercel serverless proxy) environment variables.
# Set the REAL values in the Vercel project's dashboard (Settings → Environment
# Variables), not in a local .env file that could get committed by accident.
# Never paste real values in chat, a commit message, or an issue/PR — rotate
# immediately if one ever leaks.

# Base URL for the AI Gateway (Vercel AI Gateway, or api.anthropic.com directly).
ANTHROPIC_BASE_URL=https://ai-gateway.vercel.sh

# Use ONE of these, whichever your gateway/provider issued you:
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=

# Optional: restrict CORS to your deployed frontend's origin instead of "*".
ALLOWED_ORIGIN=

# Optional: override the model used for drafting (defaults to claude-sonnet-5).
AI_MODEL=claude-sonnet-5
