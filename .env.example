# Sidekick — LINE integration (api/line-webhook.js, api/booking-*.js)
# environment variables. Set the REAL values in the Vercel project's
# dashboard (Settings → Environment Variables), not in a local .env file
# that could get committed by accident. Never paste real values in chat, a
# commit message, or an issue/PR — rotate immediately if one ever leaks.

# LINE integration — pilot/single-tenant, one Channel.
# Get these from the LINE Developers Console → your Messaging API channel.
# LINE_CHANNEL_SECRET verifies incoming webhook signatures; it is NOT the
# same thing as a channel access token (that's fetched at runtime via
# client_credentials using the two values below, not stored separately).
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Optional: where the "book a slot" link in the auto-reply points. Defaults
# to the deployed app root if unset.
LINE_BOOKING_URL=

# The freelancer's own LINE user ID (not the OA's), so booking-request.js
# can push her an alert when a new request comes in. Get this from LINE's
# webhook event logs the first time she messages her own OA — there is no
# lookup-by-name API for this. Optional: without it, bookings still work,
# she just doesn't get pushed a notification for them.
LINE_FREELANCER_USER_ID=

# Neon Postgres (sql/schema.sql) — auto-provisioned by connecting the Neon
# integration in the Vercel dashboard (Storage → Marketplace). Do not set
# this by hand; if it's missing, the integration isn't connected yet.
DATABASE_URL=
