# Freelanz — Apache config for shared hosting (e.g. Hostinger).
#
# Cache-Control discipline: the HTML shell and the service worker itself must
# always be revalidated so a new deploy (and its bumped APP_VERSION/SW_VERSION)
# is picked up promptly — these are the two files a returning visitor loads
# WITHOUT a version query string. Every other static asset is safe to cache
# moderately: app.js/tax.js/invoices.js/etc. are always requested with a
# `?v=X.Y.Z` query that changes in lockstep with a release, so an old cached
# copy is simply never requested again once index.html points at a new one.

<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <Files "sw.js">
    Header set Cache-Control "no-cache, must-revalidate"
  </Files>
  <FilesMatch "\.(js|css|svg|png|ico|json)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
</IfModule>

# No backend, no server-side includes — this is a static file host, not an app
# server, so no rewrite rules are needed (each screen is served from the SPA's
# own client-side switchScreen(), not a server route).
Options -Indexes
